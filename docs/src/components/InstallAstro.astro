---
import { Code, TabItem, Tabs } from "@astrojs/starlight/components";
---

<Tabs syncKey="packageManager">
  <TabItem label="pnpm">
    <Code lang="sh" code="pnpm create astro@latest" />
  </TabItem>
  <TabItem label="npm">
    <Code lang="sh" code="npm create astro@latest" />
  </TabItem>
  <TabItem label="yarn">
    <Code lang="sh" code="yarn create astro" />
  </TabItem>
</Tabs>
