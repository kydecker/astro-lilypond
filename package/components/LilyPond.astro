---
/// <reference path="./virtual.d.ts" />
import { escapeHtml } from "../src/util.js";

interface Props {
	/** Pre-rendered HTML from an imported `.ly` file. */
	content: string;
	/** Additional class name(s) merged onto the rendered `<svg>` or `<img>` element. */
	class?: string;
	/** Inline styles applied to the rendered `<svg>` or `<img>` element. */
	style?: string;
}

const { content, class: className, style } = Astro.props;

let html = content;
if (className) html = html.replace('class="lilypond"', `class="lilypond ${className}"`);
if (style) html = html.replace(/^<(svg|img)\b/, `<$1 style="${escapeHtml(style)}"`);
---

<Fragment set:html={html} />
