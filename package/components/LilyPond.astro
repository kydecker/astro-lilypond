---
/// <reference path="./virtual.d.ts" />
import { escapeHtml } from "../src/util.js";

interface Props {
	/** Contents of an imported `.ly` file. */
	content: string;
	class?: string;
	style?: string;
}

const { content, class: className, style } = Astro.props;

let html = content;
if (className) html = html.replace('class="lilypond"', `class="lilypond ${className}"`);
if (style) html = html.replace(/<(svg|img)\b/, `<$1 style="${escapeHtml(style)}"`);
---

<Fragment set:html={html} />
